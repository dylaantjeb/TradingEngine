# TradingEngine environment variables
# Copy this file to .env and fill in your values.
# All variables are prefixed with TE_ (Trading Engine).

# ── IBKR Connection ────────────────────────────────────────────────────────────
# Port 7497 = paper trading, 7496 = live trading
TE_IBKR_HOST=127.0.0.1
TE_IBKR_PORT=7497
TE_IBKR_CLIENT_ID=1

# ── Execution overrides (override config/universe.yaml) ────────────────────────
# TE_EXECUTION_DELAY_BARS=1
# TE_COMMISSION_PER_SIDE_USD=1.50
# TE_SLIPPAGE_TICKS_PER_SIDE=0.5
# TE_SPREAD_TICKS=1.0

# ── Risk overrides ─────────────────────────────────────────────────────────────
# TE_SESSION_START_UTC_HOUR=9
# TE_SESSION_END_UTC_HOUR=22
# TE_ATR_MIN_TICKS=4
# TE_ATR_MAX_TICKS=200
# TE_MAX_TRADES_PER_DAY=20
# TE_MIN_HOLDING_BARS=3
# TE_COOLDOWN_BARS_AFTER_EXIT=2

# ── Logging ────────────────────────────────────────────────────────────────────
# TE_LOG_DIR=logs
